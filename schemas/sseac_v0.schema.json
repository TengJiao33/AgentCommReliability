{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcommreliability.local/schemas/sseac_v0.schema.json",
  "title": "SSEAC v0 Packet Row",
  "type": "object",
  "required": [
    "packet_id",
    "task_id",
    "roles",
    "final_decider",
    "candidate_options",
    "role_budgets",
    "source_cards",
    "required_slots"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "benchmark": { "type": "string" },
    "roles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "final_decider": { "type": "string", "minLength": 1 },
    "candidate_options": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "role_budgets": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "decision_rule": { "type": "string" },
    "expected_final_decision": { "type": "string" },
    "source_cards": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceCard" },
      "minItems": 1
    },
    "required_slots": {
      "type": "array",
      "items": { "$ref": "#/$defs/requiredSlot" }
    }
  },
  "$defs": {
    "sourceCard": {
      "type": "object",
      "required": [
        "card_id",
        "source_id",
        "source_role",
        "content",
        "recipient_scope",
        "verification_state",
        "evidence_type",
        "cost"
      ],
      "properties": {
        "card_id": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "source_role": { "type": "string", "minLength": 1 },
        "content": { "type": "string" },
        "recipient_scope": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "visibility": {
          "type": "string",
          "enum": ["private", "shared", "role_scoped"]
        },
        "verification_state": {
          "type": "string",
          "enum": ["verified", "unverified", "rejected", "quarantined"]
        },
        "evidence_type": {
          "type": "string",
          "enum": ["support", "blocker", "constraint", "background", "distractor"]
        },
        "cost": { "type": "integer", "minimum": 0 },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "conflicts_with": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "provenance": { "type": "object" }
      },
      "additionalProperties": true
    },
    "requiredSlot": {
      "type": "object",
      "required": [
        "slot_id",
        "recipient",
        "option",
        "polarity",
        "acceptable_card_ids"
      ],
      "properties": {
        "slot_id": { "type": "string", "minLength": 1 },
        "recipient": { "type": "string", "minLength": 1 },
        "option": { "type": "string", "minLength": 1 },
        "polarity": {
          "type": "string",
          "enum": ["support", "enabler", "blocker", "constraint", "exclusion"]
        },
        "acceptable_card_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "required_state": {
          "type": "string",
          "enum": ["verified", "unverified_allowed"],
          "default": "verified"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
