+import asyncio
+import os
+from typing import Dict, List, Optional, Union
+
+import aiohttp
+
+from src.llm.format import Message
+from src.llm.llm import LLM
+from src.llm.llm_registry import LLMRegistry
+from src.utils.globals import CompletionTokens, PromptTokens
+
+
+def _strip_backend_prefix(model_name: str) -> str:
+    for prefix in ("vllm:", "openai:"):
+        if model_name.lower().startswith(prefix):
+            return model_name[len(prefix):]
+    return model_name
+
+
+def _convert_messages(messages) -> List[Dict[str, str]]:
+    if isinstance(messages, str):
+        return [{"role": "user", "content": messages}]
+    converted = []
+    for message in messages:
+        if isinstance(message, Message):
+            role = message.role if message.role in ("system", "user", "assistant") else "user"
+            converted.append({"role": role, "content": message.content})
+        elif isinstance(message, dict):
+            role = message.get("role", "user")
+            if role not in ("system", "user", "assistant"):
+                role = "user"
+            converted.append({"role": role, "content": str(message.get("content", ""))})
+        else:
+            converted.append({"role": "user", "content": str(message)})
+    return converted
+
+
+@LLMRegistry.register("VLLMChat")
+class VLLMChat(LLM):
+    def __init__(self, model_name: str):
+        self.model_name = _strip_backend_prefix(model_name)
+        self.base_url = os.getenv("OPENAI_BASE_URL", "http://127.0.0.1:8021/v1").rstrip("/")
+        self.api_key = os.getenv("OPENAI_API_KEY", "EMPTY")
+
+    async def agen(
+        self,
+        messages: List[Message],
+        max_tokens: Optional[int] = None,
+        temperature: Optional[float] = None,
+        num_comps: Optional[int] = None,
+    ) -> Union[List[str], str]:
+        if max_tokens is None:
+            max_tokens = self.DEFAULT_MAX_TOKENS
+        if temperature is None:
+            temperature = self.DEFAULT_TEMPERATURE
+        if num_comps is None:
+            num_comps = self.DEFUALT_NUM_COMPLETIONS
+
+        payload = {
+            "model": self.model_name,
+            "messages": _convert_messages(messages),
+            "max_tokens": max_tokens,
+            "temperature": temperature,
+            "n": num_comps,
+        }
+        headers = {"Authorization": f"Bearer {self.api_key}"}
+        async with aiohttp.ClientSession() as session:
+            async with session.post(
+                f"{self.base_url}/chat/completions",
+                headers=headers,
+                json=payload,
+                timeout=aiohttp.ClientTimeout(total=None),
+            ) as response:
+                if response.status >= 400:
+                    body = await response.text()
+                    raise RuntimeError(f"vLLM request failed: HTTP {response.status}: {body[:1000]}")
+                data = await response.json()
+
+        usage = data.get("usage") or {}
+        PromptTokens.instance().value += usage.get("prompt_tokens", 0)
+        CompletionTokens.instance().value += usage.get("completion_tokens", 0)
+        return data["choices"][0]["message"]["content"]
+
+    def gen(self, messages, max_tokens=None, temperature=None, num_comps=None):
+        return asyncio.run(self.agen(messages, max_tokens, temperature, num_comps))
