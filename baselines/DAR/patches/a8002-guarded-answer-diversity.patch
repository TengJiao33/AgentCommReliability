+def _answer_bucket(answer):
+    if answer is None:
+        return None
+    if isinstance(answer, str):
+        text = answer.strip()
+        return text if text else None
+    if isinstance(answer, float) and answer.is_integer():
+        return str(int(answer))
+    return str(answer)
+
+
+def _ordered_unique(values):
+    seen = set()
+    unique = []
+    for value in values:
+        if value in seen:
+            continue
+        seen.add(value)
+        unique.append(value)
+    return unique
+
+
+def apply_retention_guard(result, peers, last_round_final_ans, args):
+    if getattr(args, "retention_guard", "none") != "answer_diversity":
+        return result
+    if last_round_final_ans is None:
+        return result
+
+    max_retained = max(1, int(getattr(args, "retention_guard_max", len(peers))))
+    answers_by_peer = {
+        peer: last_round_final_ans[i] if i < len(last_round_final_ans) else None
+        for i, peer in enumerate(peers)
+    }
+    bucket_to_peers = {}
+    for peer in peers:
+        bucket = _answer_bucket(answers_by_peer.get(peer))
+        if bucket is not None and bucket not in bucket_to_peers:
+            bucket_to_peers[bucket] = peer
+
+    original = [peer for peer in _ordered_unique(result.get("retained_ids") or []) if peer in peers]
+    retained = list(original)
+    added = []
+    removed = []
+    notes = []
+    parseable_buckets = list(bucket_to_peers.keys())
+
+    if len(retained) == 0:
+        result["guard_mode"] = "reset"
+        result["original_retained_ids"] = original
+        result["guard_added_ids"] = []
+        result["guard_removed_ids"] = []
+        result["guard_notes"] = ["empty_retention_treated_as_reset"]
+        result["guard_parseable_buckets"] = parseable_buckets
+        result["guard_missing_parseable_buckets"] = parseable_buckets
+        return result
+
+    def retained_parseable_buckets():
+        buckets = []
+        for peer in retained:
+            bucket = _answer_bucket(answers_by_peer.get(peer))
+            if bucket is not None:
+                buckets.append(bucket)
+        return _ordered_unique(buckets)
+
+    if parseable_buckets and not retained_parseable_buckets():
+        unparseable_retained = [
+            peer for peer in retained if _answer_bucket(answers_by_peer.get(peer)) is None
+        ]
+        for peer in unparseable_retained:
+            retained.remove(peer)
+            removed.append(peer)
+        if unparseable_retained:
+            notes.append("replaced_unparseable_only_retention")
+
+    def duplicate_retained_peers():
+        seen_buckets = set()
+        duplicates = []
+        for peer in retained:
+            bucket = _answer_bucket(answers_by_peer.get(peer))
+            if bucket is None:
+                continue
+            if bucket in seen_buckets:
+                duplicates.append(peer)
+            else:
+                seen_buckets.add(bucket)
+        return duplicates
+
+    while True:
+        selected_buckets = set(retained_parseable_buckets())
+        missing_buckets = [bucket for bucket in parseable_buckets if bucket not in selected_buckets]
+        if not missing_buckets:
+            break
+
+        if len(retained) >= max_retained:
+            removable = duplicate_retained_peers()
+            if not removable:
+                removable = [
+                    peer for peer in retained if _answer_bucket(answers_by_peer.get(peer)) is None
+                ]
+            if not removable:
+                break
+            peer = removable[-1]
+            retained.remove(peer)
+            removed.append(peer)
+
+        bucket = missing_buckets[0]
+        peer = bucket_to_peers[bucket]
+        if peer not in retained:
+            retained.append(peer)
+            added.append(peer)
+
+    selected_buckets = set(retained_parseable_buckets())
+    missing_buckets = [bucket for bucket in parseable_buckets if bucket not in selected_buckets]
+    if added:
+        notes.append("added_missing_parseable_answer_bucket")
+    if missing_buckets:
+        notes.append("max_retained_prevented_full_answer_diversity")
+
+    result["original_retained_ids"] = original
+    result["retained_ids"] = retained
+    result["dropped_ids"] = [peer for peer in peers if peer not in retained]
+    result["guard_mode"] = "guarded"
+    result["guard_added_ids"] = added
+    result["guard_removed_ids"] = removed
+    result["guard_notes"] = notes
+    result["guard_parseable_buckets"] = parseable_buckets
+    result["guard_missing_parseable_buckets"] = missing_buckets
+    return result
+
